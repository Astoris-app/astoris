# ── Astoris Konfiguration ──────────────────────────────────────────
# Diese Datei ist eine Vorlage. Kopiere sie nach .env und passe sie an.

# Engine-Anbindung (die KI-Engine, die Chat beantwortet — z.B. Clawy/agent-v2).
ENGINE_URL=http://localhost:8081

# ENGINE_API_KEY — der X-API-Key deiner Engine.
#   Ohne diesen Schlüssel bleibt der Chat im Demo-Modus (alles andere läuft).
#   Aus Sicherheitsgründen NICHT als Wert hier eintragen — in der echten .env setzen.

# ASTORIS_MASTER_KEY (optional) — 64 Hex-Zeichen zum Verschlüsseln der Zugangsdaten.
#   Wird sonst automatisch generiert und unter data/.master.key (chmod 600) abgelegt.

# ── Docker / Self-Hosting ─────────────────────────────────────────
# Deine Domain für automatisches HTTPS (leer/localhost = self-signed):
ASTORIS_DOMAIN=localhost
# Öffentliche HTTPS-URL (für sichere Cookies) — muss zur Domain passen:
ASTORIS_ORIGIN=https://localhost

# ── Erst-Einrichtung absichern (optional) ──
# ASTORIS_SETUP_TOKEN: schützt das Erst-Setup gegen Netzwerk-Übernahme. Nur nötig bei
# Reverse-Proxy OHNE Tailscale (lokal/Tailscale funktioniert ohne). Zufälligen
# Wert setzen und im Welcome-Schritt eingeben.
# ASTORIS_SETUP_TOKEN=

# ── Verbindungs-Credentials in .env spiegeln (optional, Standard AUS) ──
# ASTORIS_MIRROR_ENV=true aktiviert die zusätzliche Klartext-Spiegelung der Verbindungsfelder
# als ASTORIS_<CONNECTOR>_<FELD>. Standard: nur verschlüsselt in data/.
# Wenn aktiviert: nicht committen, wie data/ behandeln.
# ASTORIS_MIRROR_ENV=false
